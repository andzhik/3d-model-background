      "blendOutput": "blender/generated/pipeline-test.blend",
      "expectedObjects": ["PipelineTestMesh"],
      "expectedMaterials": ["PipelineTestMaterial"],
      "minBytes": 100
    },
    {
      "id": "environment-mountains",
      "generator": "blender/scripts/generate_mountains.py",
